<Page x:Class="EAClient.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White"
      FontFamily="Arial">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="1" Grid.Column="1"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="12"
                Padding="48,40">
            <StackPanel>

                <!-- Logo area -->
                <TextBlock Text="eAsistent"
                           FontSize="38"
                           FontWeight="Bold"
                           Foreground="#0066CC"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Prijavite se v svoj račun"
                           FontSize="14"
                           Foreground="#888"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,36"/>

                <!-- Username -->
                <TextBlock Text="Uporabniško ime:"
                           FontSize="13"
                           Foreground="#333"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6" Margin="0,0,0,18">
                    <TextBox x:Name="UsernameBox"
                             FontSize="14"
                             Padding="10,9"
                             BorderThickness="0"
                             Background="Transparent"
                             KeyDown="Input_KeyDown"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="Geslo:"
                           FontSize="13"
                           Foreground="#333"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="6" Margin="0,0,0,28">
                    <PasswordBox x:Name="PasswordBox"
                                 FontSize="14"
                                 Padding="10,9"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 KeyDown="Input_KeyDown"/>
                </Border>

                <!-- Error text -->
                <TextBlock x:Name="ErrorText"
                           Foreground="#CC0000"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Margin="0,0,0,14"/>

                <!-- Status text -->
                <TextBlock x:Name="StatusText"
                           Foreground="#0066CC"
                           FontSize="13"
                           Visibility="Collapsed"
                           Margin="0,0,0,14"/>

                <!-- Login button -->
                <Button x:Name="LoginButton"
                        Content="Prijava"
                        FontSize="15"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="LoginButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#0066CC"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0,13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#0052A3"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#AAAAAA"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Page>
