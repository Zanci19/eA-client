<Page x:Class="EAClient.Pages.CommunicationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="TitleBar" Padding="20,14">
            <TextBlock Text="Komunikacija" Foreground="White" FontSize="20" FontWeight="Bold"/>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="ChannelsCard" Grid.Column="0" Padding="18">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock x:Name="UnseenBadge" DockPanel.Dock="Right" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="Pogovori" FontSize="16" FontWeight="Bold"/>
                    </DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="TabMessages"  Content="Sporočila"     Click="TabMessages_Click"  Padding="10,5" Margin="0,0,6,0"/>
                        <Button x:Name="TabBoard"     Content="Oglasna deska" Click="TabBoard_Click"    Padding="10,5" Margin="0,0,6,0"/>
                        <Button x:Name="TabSms"       Content="SMS"           Click="TabSms_Click"      Padding="10,5"/>
                    </StackPanel>
                    <ListBox x:Name="ChannelsList" SelectionChanged="ChannelsList_SelectionChanged" BorderThickness="0"/>
                </DockPanel>
            </Border>

            <Border x:Name="MessagesCard" Grid.Column="2" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="ConversationTitle" Text="Izberi pogovor" FontSize="16" FontWeight="Bold"/>
                        <TextBlock x:Name="ConversationMeta" Margin="0,4,0,0" FontSize="12"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,16,0,16">
                        <StackPanel x:Name="MessagesPanel"/>
                    </ScrollViewer>

                    <Border Grid.Row="2" x:Name="ComposerCard" Padding="14">
                        <DockPanel>
                            <Button x:Name="RefreshButton" Content="Osveži" DockPanel.Dock="Right" Click="RefreshButton_Click" Margin="12,0,0,0" Padding="16,8"/>
                            <Button x:Name="SendButton" Content="Pošlji" DockPanel.Dock="Right" Click="SendButton_Click" Margin="12,0,0,0" Padding="18,8"/>
                            <TextBox x:Name="MessageInput" AcceptsReturn="True" MinHeight="68" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <Button x:Name="ComposeFloatingButton"
                    Grid.Column="2"
                    Width="64"
                    Height="64"
                    Content="＋"
                    FontSize="28"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,24,24"
                    Click="ComposeFloatingButton_Click"
                    Cursor="Hand"/>
        </Grid>

        <Grid x:Name="ComposeOverlay" Grid.RowSpan="2" Background="#CCFFFFFF" Visibility="Collapsed">
            <Border x:Name="ComposeOverlayCard"
                    Margin="28"
                    Padding="24"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <Button x:Name="CloseComposeButton" Content="Zapri" DockPanel.Dock="Right" Click="CloseComposeButton_Click" Padding="14,8" Margin="12,0,0,0"/>
                        <TextBlock Text="Novo sporočilo" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </DockPanel>

                    <TextBlock x:Name="NewMessageStatus" Grid.Row="1" Margin="0,10,0,0" FontSize="12" Text="Poišči prejemnika in pošlji povsem novo sporočilo."/>

                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <DockPanel>
                            <Button x:Name="SearchRecipientsButton" Content="Najdi" DockPanel.Dock="Right" Click="SearchRecipientsButton_Click" Margin="12,0,0,0" Padding="16,8"/>
                            <TextBox x:Name="NewMessageRecipientInput" MinHeight="38" VerticalContentAlignment="Center" ToolTip="Vnesi ime ali priimek prejemnika"/>
                        </DockPanel>

                        <ListBox x:Name="ContactResultsList" Margin="0,10,0,0" Height="140" BorderThickness="0" SelectionChanged="ContactResultsList_SelectionChanged"/>
                    </StackPanel>

                    <Grid Grid.Row="3" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBox x:Name="NewMessageTitleInput" MinHeight="38" VerticalContentAlignment="Center" ToolTip="Zadeva"/>
                        <TextBox x:Name="NewMessageBodyInput" Grid.Row="1" Margin="0,10,0,0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" ToolTip="Sporočilo"/>
                    </Grid>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button x:Name="SendNewMessageButton" Content="Pošlji novo sporočilo" Click="SendNewMessageButton_Click" Padding="18,8"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
