<Page x:Class="EAClient.Pages.CommunicationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="TitleBar" Padding="20,14">
            <TextBlock Text="Komunikacija" Foreground="White" FontSize="20" FontWeight="Bold"/>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="ChannelsCard" Grid.Column="0" Padding="18">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Pogovori" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                    <ListBox x:Name="ChannelsList" SelectionChanged="ChannelsList_SelectionChanged" BorderThickness="0"/>
                </DockPanel>
            </Border>

            <Border x:Name="MessagesCard" Grid.Column="2" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="ConversationTitle" Text="Izberi pogovor" FontSize="16" FontWeight="Bold"/>
                        <TextBlock x:Name="ConversationMeta" Margin="0,4,0,0" FontSize="12"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,16,0,16">
                        <StackPanel x:Name="MessagesPanel"/>
                    </ScrollViewer>

                    <Border Grid.Row="2" x:Name="ComposerCard" Padding="14" Margin="0,0,0,16">
                        <DockPanel>
                            <Button x:Name="RefreshButton" Content="Osveži" DockPanel.Dock="Right" Click="RefreshButton_Click" Margin="12,0,0,0" Padding="16,8"/>
                            <Button x:Name="SendButton" Content="Pošlji" DockPanel.Dock="Right" Click="SendButton_Click" Margin="12,0,0,0" Padding="18,8"/>
                            <TextBox x:Name="MessageInput" AcceptsReturn="True" MinHeight="68" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="3" x:Name="NewMessageCard" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Novo sporočilo" FontSize="15" FontWeight="Bold"/>
                            <TextBlock x:Name="NewMessageStatus" Margin="0,4,0,0" FontSize="12" Text="Poišči prejemnika in pošlji povsem novo sporočilo."/>

                            <DockPanel Margin="0,12,0,0">
                                <Button x:Name="SearchRecipientsButton" Content="Najdi" DockPanel.Dock="Right" Click="SearchRecipientsButton_Click" Margin="12,0,0,0" Padding="16,8"/>
                                <TextBox x:Name="NewMessageRecipientInput" MinHeight="38" VerticalContentAlignment="Center" Text="" ToolTip="Vnesi ime ali priimek prejemnika"/>
                            </DockPanel>

                            <ListBox x:Name="ContactResultsList" Margin="0,10,0,0" Height="120" BorderThickness="0" SelectionChanged="ContactResultsList_SelectionChanged"/>

                            <TextBox x:Name="NewMessageTitleInput" Margin="0,10,0,0" MinHeight="38" VerticalContentAlignment="Center" ToolTip="Zadeva"/>
                            <TextBox x:Name="NewMessageBodyInput" Margin="0,10,0,0" AcceptsReturn="True" MinHeight="90" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" ToolTip="Sporočilo"/>
                            <Button x:Name="SendNewMessageButton" Content="Pošlji novo sporočilo" Click="SendNewMessageButton_Click" Margin="0,12,0,0" Padding="18,8" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
