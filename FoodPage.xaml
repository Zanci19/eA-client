<Page x:Class="EAClient.Pages.FoodPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" x:Name="TitleBar" Padding="20,14">
            <TextBlock Text="Šolska prehrana" Foreground="White" FontSize="20" FontWeight="Bold"/>
        </Border>

        <Border Grid.Row="1" x:Name="NavBar" BorderThickness="0,0,0,1" Padding="16,10">
            <DockPanel>
                <Button x:Name="PrevDayButton" Content="◀  Prejšnji dan" DockPanel.Dock="Left" Click="PrevDay_Click"/>
                <Button x:Name="NextDayButton" Content="Naslednji dan  ▶" DockPanel.Dock="Right" Click="NextDay_Click"/>
                <TextBlock x:Name="WeekLabel" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="LoadingText" Text="Nalaganje..." FontSize="16"/>
            </StackPanel>

            <StackPanel x:Name="ErrorPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="ErrorText" Foreground="#CC0000" TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center" FontSize="14"/>
                <Button x:Name="RetryButton" Content="Poskusi znova" Margin="0,14,0,0" Padding="20,9" Click="Retry_Click" Cursor="Hand"/>
            </StackPanel>

            <ScrollViewer x:Name="ContentPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel x:Name="FoodContainer" HorizontalAlignment="Stretch"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
