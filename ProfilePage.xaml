<Page x:Class="EAClient.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA"
      FontFamily="Arial">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0066CC" Padding="20,14">
            <TextBlock Text="Profil" Foreground="White" FontSize="20" FontWeight="Bold"/>
        </Border>

        <Grid Grid.Row="1">
            <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Nalaganje..." FontSize="16" Foreground="#888"/>
            </StackPanel>

            <StackPanel x:Name="ErrorPanel" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="ErrorText" Foreground="#CC0000" TextWrapping="Wrap"
                           MaxWidth="420" TextAlignment="Center" FontSize="14"/>
                <Button Content="Poskusi znova" Margin="0,14,0,0" Padding="20,9" Click="Retry_Click"
                        Cursor="Hand" Background="#0066CC" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <ScrollViewer x:Name="ContentPanel" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="24">
                <StackPanel MaxWidth="600">

                    <!-- Avatar + name -->
                    <Border Background="White" CornerRadius="8" BorderBrush="#E4E8F0"
                            BorderThickness="1" Padding="24" Margin="0,0,0,16">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="80" Height="80" CornerRadius="40"
                                    Background="#0066CC" HorizontalAlignment="Center"
                                    Margin="0,0,0,16">
                                <TextBlock x:Name="AvatarText" Text="U"
                                           FontSize="36" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="DisplayNameText" Text=""
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="#1C2333"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="UserTypeText" Text=""
                                       FontSize="14" Foreground="#888"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Info fields -->
                    <Border Background="White" CornerRadius="8" BorderBrush="#E4E8F0"
                            BorderThickness="1" Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Podatki o računu" FontSize="15" FontWeight="Bold"
                                       Foreground="#0066CC" Margin="0,0,0,14"/>
                            <StackPanel x:Name="InfoPanel"/>
                        </StackPanel>
                    </Border>

                    <!-- Token info -->
                    <Border Background="White" CornerRadius="8" BorderBrush="#E4E8F0"
                            BorderThickness="1" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Seja" FontSize="15" FontWeight="Bold"
                                       Foreground="#0066CC" Margin="0,0,0,14"/>
                            <StackPanel x:Name="TokenPanel"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
