<Page x:Class="EAClient.Pages.EvaluationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA"
      FontFamily="Arial">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0066CC" Padding="20,14">
            <TextBlock Text="Ocenjevanja" Foreground="White" FontSize="20" FontWeight="Bold"/>
        </Border>

        <Grid Grid.Row="1">
            <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Nalaganje..." FontSize="16" Foreground="#888"/>
            </StackPanel>

            <StackPanel x:Name="ErrorPanel" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="ErrorText" Foreground="#CC0000" TextWrapping="Wrap"
                           MaxWidth="420" TextAlignment="Center" FontSize="14"/>
                <Button Content="Poskusi znova" Margin="0,14,0,0" Padding="20,9" Click="Retry_Click"
                        Cursor="Hand" Background="#0066CC" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <ScrollViewer x:Name="ContentPanel" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel x:Name="EvalContainer"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
