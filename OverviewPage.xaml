<Page x:Class="EAClient.Pages.OverviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA"
      FontFamily="Arial">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="#0066CC" Padding="20,14">
            <TextBlock Text="Pregled" Foreground="White" FontSize="20" FontWeight="Bold"/>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="1">

            <!-- Loading -->
            <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Nalaganje..." FontSize="16" Foreground="#888"/>
            </StackPanel>

            <!-- Error -->
            <StackPanel x:Name="ErrorPanel" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="ErrorText" Foreground="#CC0000" TextWrapping="Wrap"
                           MaxWidth="420" TextAlignment="Center" FontSize="14"/>
                <Button Content="Poskusi znova" Margin="0,14,0,0" Padding="20,9"
                        Click="Retry_Click" Cursor="Hand"
                        Background="#0066CC" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer x:Name="ContentPanel" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Today's timetable -->
                    <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="8"
                            Padding="20" BorderBrush="#E4E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📅  Današnji urnik" FontSize="15" FontWeight="Bold"
                                       Foreground="#0066CC" Margin="0,0,0,14"/>
                            <StackPanel x:Name="TodayTimetablePanel"/>
                        </StackPanel>
                    </Border>

                    <!-- Upcoming homework -->
                    <Border Grid.Row="0" Grid.Column="2" Background="White" CornerRadius="8"
                            Padding="20" BorderBrush="#E4E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📚  Domače naloge (7 dni)" FontSize="15" FontWeight="Bold"
                                       Foreground="#0066CC" Margin="0,0,0,14"/>
                            <StackPanel x:Name="HomeworkPanel"/>
                        </StackPanel>
                    </Border>

                    <!-- Upcoming evaluations -->
                    <Border Grid.Row="2" Grid.Column="0" Background="White" CornerRadius="8"
                            Padding="20" BorderBrush="#E4E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📋  Prihajajoča ocenjevanja" FontSize="15" FontWeight="Bold"
                                       Foreground="#0066CC" Margin="0,0,0,14"/>
                            <StackPanel x:Name="EvaluationsPanel"/>
                        </StackPanel>
                    </Border>

                    <!-- Today's food -->
                    <Border Grid.Row="2" Grid.Column="2" Background="White" CornerRadius="8"
                            Padding="20" BorderBrush="#E4E8F0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="🍽  Današnja prehrana" FontSize="15" FontWeight="Bold"
                                       Foreground="#0066CC" Margin="0,0,0,14"/>
                            <StackPanel x:Name="FoodPanel"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </ScrollViewer>

        </Grid>
    </Grid>
</Page>
